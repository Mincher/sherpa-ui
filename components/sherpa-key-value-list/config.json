{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "sherpa-key-value-list",
  "description": "Semantic description list using the native <dl> element. Content is authored as <dt>/<dd> pairs in the template.",
  "attributes": {
    "data-layout": { "type": "string", "options": ["horizontal", "vertical"], "default": "horizontal", "description": "Key/value arrangement (CSS flex-direction)" },
    "data-density": { "type": "string", "options": ["compact", "base", "comfortable"], "default": "base", "description": "Spacing density" },
    "data-striped": { "type": "boolean", "default": false, "description": "Alternate row backgrounds" },
    "data-bordered": { "type": "boolean", "default": true, "description": "Show item separators" },
    "data-truncate": { "type": "boolean", "default": false, "description": "Clip long values with ellipsis" },
    "data-key-width": { "type": "string", "default": "auto", "description": "Key column width (CSS grid column)" }
  },
  "ddAttributes": {
    "data-type": { "options": ["monospace"], "description": "Value presentation variant" },
    "data-status": { "options": ["success", "critical", "warning", "urgent", "info"], "description": "Status colour via status-styles.css tokens" }
  },
  "example": "<sherpa-key-value-list data-layout=\"horizontal\" data-bordered>\n  <dt>Name</dt>\n  <dd>John Doe</dd>\n  <dt>Email</dt>\n  <dd data-type=\"monospace\">john@example.com</dd>\n  <dt>Status</dt>\n  <dd data-status=\"success\">Active</dd>\n</sherpa-key-value-list>"
}
