{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "name": "sherpa-container-pdf",
  "description": "PDF-optimized container with fixed pixel dimensions for export",
  "attributes": {
    "data-content-type": { "type": "string", "options": ["metric", "table", "barchart", "sparkline", "custom"], "description": "Type of content displayed" },
    "width": { "type": "number", "description": "Fixed width in pixels for PDF export" },
    "height": { "type": "number", "description": "Fixed height in pixels for PDF export" }
  },
  "methods": { "setData(data)": "Set container data", "getData()": "Get container data" },
  "content": { "title": "Sales Overview", "contentType": "metric", "width": 400, "height": 300 },
  "example": "<sherpa-container-pdf data-content-type=\"barchart\" width=\"600\" height=\"400\"></sherpa-container-pdf>"
}
