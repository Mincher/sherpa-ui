  "category": "core",
  "baseClass": "SherpaElement",
  "attributes": [
    {
      "name": "data-heading",
      "type": "string",
      "description": "Header title text"
    },
    {
      "name": "data-open",
      "type": "boolean",
      "description": "Shows the popover"
    },
    {
      "name": "data-anchor",
      "type": "string",
