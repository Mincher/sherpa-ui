    },
    {
      "name": "data-content",
      "type": "enum",
      "description": "\"static\" — opts out of grid; stacks children"
    }
  ],
  "slots": [
    {
      "name": "",
      "description": "sherpa-container children"
    }
  ],
  "events": [],
  "cssProperties": [
    {
      "name": "--maxColCount",
      "description": "Integer column count (default 12, registered)"
    },
    {
      "name": "--row-height",
      "description": "Row height (default 160px, registered)"
    }
  ]
}
