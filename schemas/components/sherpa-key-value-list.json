{
  "tagName": "sherpa-key-value-list",
  "description": "Semantic description list built on the native <dl> element. Content authored as <dt>/<dd> pairs. Layout, density, striping and borders controlled via host attributes and CSS.",
  "category": "data-display",
  "baseClass": "SherpaElement",
  "attributes": [
    {
      "name": "layout",
      "type": "enum",
      "description": "horizontal | vertical (default: horizontal)",
      "enumValues": [
        "horizontal",
        "vertical"
      ]
    },
    {
      "name": "density",
      "type": "enum",
      "description": "compact | base | comfortable (default: base)",
      "enumValues": [
        "compact",
        "base",
        "comfortable"
      ]
    },
    {
      "name": "data-striped",
      "type": "boolean",
      "description": "Alternate row backgrounds"
    },
    {
      "name": "data-bordered",
      "type": "boolean",
      "description": "Show borders (default: true)"
    },
    {
      "name": "truncate",
      "type": "boolean",
      "description": "Clip long values with ellipsis"
    },
    {
      "name": "key-width",
      "type": "string",
      "description": "Key column width (default: auto)"
    },
    {
      "name": "data-type",
      "type": "enum",
      "description": "Template variant"
    }
  ],
  "slots": [],
  "events": []
}
