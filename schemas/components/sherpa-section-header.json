  "events": [],
  "properties": [
    {
      "name": "heading",
      "type": "string",
      "description": "Getter/setter for data-label"
    },
    {
      "name": "headingType",
      "type": "string",
      "description": "Getter/setter for data-heading-level"
    },
    {
      "name": "hasDivider",
      "type": "boolean",
      "description": "Getter/setter for data-divider"
    }
  ]
