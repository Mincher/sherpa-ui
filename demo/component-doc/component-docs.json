      "defaultHtml": "<sherpa-menu-item data-type=\"heading\">Actions</sherpa-menu-item>\n<ul data-group=\"actions\">\n  <li><sherpa-menu-item data-icon=\"\uf067\" data-action=\"add\">Add item</sherpa-menu-item></li>\n  <li><sherpa-menu-item data-icon=\"\uf044\" data-action=\"edit\">Edit</sherpa-menu-item></li>\n  <li><sherpa-menu-item data-icon=\"\uf1f8\" data-action=\"delete\" data-status=\"critical\">Delete</sherpa-menu-item></li>\n</ul>\n<hr>\n<sherpa-menu-item data-type=\"heading\">Options</sherpa-menu-item>\n<ul data-group=\"options\">\n  <li><sherpa-menu-item data-selection=\"checkbox\" checked data-keep-open>Show labels</sherpa-menu-item></li>\n  <li><sherpa-menu-item data-selection=\"checkbox\" data-keep-open>Compact view</sherpa-menu-item></li>\n</ul>",
