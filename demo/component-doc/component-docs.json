        { "name": "data-drag-handle", "type": "boolean" },
        { "name": "data-close-button", "type": "boolean" },
        { "name": "data-search", "type": "boolean" },
        {
          "name": "data-density",
          "type": "enum",
          "options": ["compact", "comfortable"]
        }
