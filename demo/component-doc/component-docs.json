{
  "components": {
    "sherpa-barchart": {
      "component": "sherpa-barchart",
      "label": "Bar Chart",
      "description": "Adaptive bar chart with automatic orientation. Supports stacked bars, category limiting, and responsive legend.",
      "path": "components/sherpa-barchart",
      "nestedComponents": ["sherpa-header"],
      "attributes": [
        { "name": "data-loading", "type": "boolean" },
        { "name": "data-stacked", "type": "boolean" },
        {
          "name": "data-title",
          "type": "string",
          "default": "Revenue by Segment"
        },
        {
          "name": "data-orientation",
          "type": "enum",
          "options": ["horizontal", "vertical"]
        },
        { "name": "data-label", "type": "string" },
        { "name": "data-show-header", "type": "boolean", "default": true },
        {
          "name": "data-show-header-controls",
          "type": "boolean",
          "default": true
        },
        { "name": "data-show-view-menu", "type": "boolean", "default": true }
      ],
      "slots": [],
      "controls": { "defaultSlot": false, "namedSlots": false },
      "sampleData": {
        "source": "/data/queries/doc-samples.json",
        "key": "barchart"
      }
    },
    "sherpa-button": {
      "component": "sherpa-button",
      "label": "Button",
      "description": "Web Component button where the host element IS the button. Supports icons, labels, variants, sizes, and attached menus.",
      "path": "components/sherpa-button",
      "attributes": [
        { "name": "data-label", "type": "string", "default": "Button" },
        {
          "name": "data-variant",
          "type": "enum",
          "default": "primary",
          "options": ["primary", "secondary", "tertiary"]
        },
        {
          "name": "data-size",
          "type": "enum",
          "options": ["small", "medium", "large"]
        },
        { "name": "data-icon-start", "type": "string" },
        { "name": "data-icon-end", "type": "string" },
        {
          "name": "data-icon-weight",
          "type": "enum",
          "options": ["fa-solid", "fa-regular", "fa-light"]
        },
        { "name": "data-active", "type": "boolean" },
        {
          "name": "data-status",
          "type": "enum",
          "options": ["success", "critical", "warning", "info", "urgent"]
        },
        { "name": "data-menu", "type": "boolean" },
        { "name": "disabled", "type": "boolean" }
      ],
      "slots": [],
      "controls": { "defaultSlot": false, "namedSlots": false }
    },
    "sherpa-card": {
      "component": "sherpa-card",
      "label": "Card",
      "description": "Card container with header, content, and footer areas. Supports selected, interactive, and elevated states.",
      "path": "components/sherpa-card",
      "nestedComponents": [
        "sherpa-key-value-list",
        "sherpa-tag",
        "sherpa-button"
      ],
      "attributes": [
        { "name": "data-label", "type": "string" },
        { "name": "data-description", "type": "string" },
        { "name": "data-selected", "type": "boolean" },
        { "name": "data-interactive", "type": "boolean" },
        {
          "name": "data-elevation",
          "type": "enum",
          "default": "sm",
          "options": ["none", "sm", "md", "lg"]
        },
        { "name": "disabled", "type": "boolean" }
      ],
      "slots": [
        {
          "name": "header",
          "html": "<span slot=\"header\">Custom Header</span>"
        },
        {
          "name": "footer",
          "html": "<div slot=\"footer\"><sherpa-button data-variant=\"tertiary\" data-label=\"Details\"></sherpa-button></div>"
        }
      ],
      "defaultHtml": "<p>Monitor key performance indicators across all active regions. Use the controls below to filter by date range or category.</p>\n<sherpa-key-value-list data-layout=\"horizontal\" data-density=\"compact\">\n  <dt>Status</dt><dd><sherpa-tag data-status=\"success\">Active</sherpa-tag></dd>\n  <dt>Region</dt><dd>North America</dd>\n  <dt>Updated</dt><dd>2 hours ago</dd>\n</sherpa-key-value-list>"
    },
    "sherpa-check": {
      "component": "sherpa-check",
      "label": "Check",
      "description": "Checkbox and radio button input. Uses multi-template support to render either type based on the data-type attribute.",
      "path": "components/sherpa-check",
      "attributes": [
        {
          "name": "data-type",
          "type": "enum",
          "default": "checkbox",
          "options": ["checkbox", "radio"]
        },
        {
          "name": "data-label",
          "type": "string",
          "default": "Enable notifications"
        },
        {
          "name": "data-description",
          "type": "string",
          "default": "Receive alerts when activity occurs"
        },
        {
          "name": "data-status",
          "type": "enum",
          "options": ["critical", "warning", "success", "info"]
        },
        { "name": "checked", "type": "boolean" },
        { "name": "indeterminate", "type": "boolean" },
        { "name": "disabled", "type": "boolean" },
        { "name": "required", "type": "boolean" },
        { "name": "name", "type": "string" },
        { "name": "value", "type": "string" }
      ],
      "slots": [],
      "controls": { "defaultSlot": false, "namedSlots": false }
    },
    "sherpa-container": {
      "component": "sherpa-container",
      "label": "Container",
      "description": "Dashboard card with header, metrics, and data sections. Content is defined by a content template or inline child elements.",
      "path": "components/sherpa-container",
      "nestedComponents": [
        "sherpa-header",
        "sherpa-barchart",
        "sherpa-data-grid",
        "sherpa-metric"
      ],
      "attributes": [
        { "name": "data-title", "type": "string", "default": "Sales Overview" },
        { "name": "data-content", "type": "string" },
        {
          "name": "data-col-span",
          "type": "enum",
          "default": "6",
          "options": ["3", "6", "9", "12"]
        },
        {
          "name": "data-row-span",
          "type": "enum",
          "default": "2",
          "options": ["1", "2", "3", "4", "5", "6"]
        },
        { "name": "data-editable", "type": "boolean" }
      ],
      "slots": [],
      "controls": { "defaultSlot": false, "namedSlots": false },
      "containerDemo": { "source": "/data/queries/sales-demo.json" }
    },
    "sherpa-container-pdf": {
      "component": "sherpa-container-pdf",
      "label": "Container PDF",
      "description": "PDF export container. Renders container data in a print-optimized layout with title, metrics, and stacked chart/table sections.",
      "path": "components/sherpa-container-pdf",
      "nestedComponents": [
        "sherpa-container",
        "sherpa-barchart",
        "sherpa-data-grid"
      ],
      "attributes": [
        {
          "name": "data-theme",
          "type": "enum",
          "default": "light",
          "options": ["light"]
        },
        { "name": "data-pdf-mode", "type": "boolean" }
      ],
      "slots": [],
      "controls": { "defaultSlot": false, "namedSlots": false },
      "containerPdfDemo": { "source": "/data/queries/sales-demo.json" }
    },
    "sherpa-dialog": {
      "component": "sherpa-dialog",
      "label": "Dialog",
      "description": "Modal dialog built on native HTML <dialog>. Includes an internal sherpa-header and sherpa-footer.",
      "path": "components/sherpa-dialog",
      "nestedComponents": [
        "sherpa-header",
        "sherpa-footer",
        "sherpa-button",
        "sherpa-message"
      ],
      "attributes": [
        { "name": "data-label", "type": "string", "default": "Dialog Title" },
        { "name": "data-subtitle", "type": "string" },
        {
          "name": "data-size",
          "type": "enum",
          "default": "medium",
          "options": ["small", "medium", "large", "full"]
        },
        { "name": "data-open", "type": "boolean" },
        { "name": "data-dismissible", "type": "boolean", "default": true }
      ],
      "slots": [
        {
          "name": "heading",
          "html": "<span slot=\"heading\">Custom Heading</span>"
        },
        {
          "name": "footer",
          "html": "<div slot=\"footer\"><sherpa-button data-variant=\"secondary\" data-label=\"Cancel\"></sherpa-button>\n<sherpa-button data-variant=\"primary\" data-label=\"Confirm\"></sherpa-button></div>"
        }
      ],
      "defaultHtml": "<p>Are you sure you want to proceed? This action will update the following items:</p>\n<sherpa-message data-status=\"warning\"><strong slot=\"heading\">Warning</strong>This cannot be undone.</sherpa-message>",
      "demoActions": [
        { "label": "Show", "action": "show" },
        { "label": "Hide", "action": "hide" }
      ]
    },
    "sherpa-empty-state": {
      "component": "sherpa-empty-state",
      "label": "Empty State",
      "description": "Empty-state placeholder with illustration, heading, description, action buttons, and footer.",
      "path": "components/sherpa-empty-state",
      "nestedComponents": ["sherpa-button"],
      "attributes": [
        {
          "name": "data-label",
          "type": "string",
          "default": "No results found"
        },
        {
          "name": "data-description",
          "type": "string",
          "default": "Try adjusting your search or filters to find what you're looking for."
        },
        {
          "name": "data-illustration",
          "type": "enum",
          "default": "search",
          "options": ["empty", "search", "folder", "data", "error", "success"]
        },
        { "name": "data-small-print", "type": "string" }
      ],
      "slots": [
        {
          "name": "actions",
          "html": "<sherpa-button slot=\"actions\" data-variant=\"primary\" data-label=\"Clear filters\"></sherpa-button>"
        }
      ],
      "defaultContent": ""
    },
